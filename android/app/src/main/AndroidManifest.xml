<?xml version="1.0" encoding="utf-8"?>
<!-- Luhambo-Aufnahme: GPS-Track + Fotos aufzeichnen, Touren hochladen und im
     WebView-Player abspielen. Kein ACCESS_BACKGROUND_LOCATION nötig — der
     Foreground-Service startet, während die App im Vordergrund ist. -->
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.CAMERA" />
    <!-- Video-Ton (M4); ohne die Erlaubnis wird stumm aufgenommen -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_LOCATION" />
    <uses-permission android:name="android.permission.INTERNET" />

    <uses-feature android:name="android.hardware.camera" android:required="false" />

    <application
        android:name=".LuhamboApp"
        android:label="Luhambo"
        android:icon="@mipmap/ic_launcher"
        android:theme="@style/Theme.Luhambo"
        android:usesCleartextTraffic="false"
        android:networkSecurityConfig="@xml/netz_sicherheit"
        android:supportsRtl="true">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:configChanges="orientation|screenSize|keyboardHidden">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <service
            android:name=".aufzeichnung.AufzeichnungsService"
            android:exported="false"
            android:foregroundServiceType="location" />
    </application>
</manifest>
