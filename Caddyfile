# Statisches Ausliefern des Vite-Builds + Proxy zum Luhambo-Backend.
# Auf dem VPS setzt SITE_ADDRESS die Domain (Caddy übernimmt dann TLS via
# Let's Encrypt automatisch); lokal (docker run/compose ohne Domain) fällt
# es auf :8080 zurück — dort ohne TLS.
{
	admin off
}

{$SITE_ADDRESS::8080} {
	root * /srv
	encode gzip zstd

	# API + Medien zum Backend-Container durchreichen (Compose-Netz).
	# API_UPSTREAM überschreibbar (z. B. lokales Testen gegen den Host).
	handle /api/* {
		reverse_proxy {$API_UPSTREAM:api:8787}
	}

	handle {
		# Gehashte Vite-Assets sind unveränderlich → aggressiv cachen.
		@assets path /assets/*
		header @assets Cache-Control "public, max-age=31536000, immutable"

		# HTML-Einstiegsseiten nie langfristig cachen, damit neue Deploys sofort
		# greifen. Sie verweisen auf die gehashten Assets — bleibt die HTML im
		# Cache, bleibt auch die alte App-Version, obwohl neue Assets bereitstehen.
		# FRÜHER stand hier nur /index.html: beim Umzug des Players auf
		# /erlebnis.html (v0.8.0) wurde die Regel nicht mitgezogen, wodurch die
		# App-WebView nach einem Deploy weiter das alte Bundle lud (am Gerät
		# beobachtet). Der Glob deckt jetzt auch künftige Seiten ab.
		@html path / *.html
		header @html Cache-Control "no-cache"

		# Unbekannte Pfade auf index.html zurückfallen (App nutzt ?tour=-Query,
		# keine echten Unterpfade — schadet aber nicht).
		try_files {path} /index.html
		file_server
	}
}
