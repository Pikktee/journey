{
  "name": "luhambo-server",
  "version": "0.1.0",
  "private": true,
  "description": "Luhambo-Backend: nimmt aufgezeichnete Touren entgegen, reichert sie an (Benennung, Wetter, Medien) und liefert sie an den Player aus.",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@node-rs/argon2": "^2.0.2",
    "better-sqlite3": "^12.2.0",
    "fastify": "^5.4.0",
    "nanoid": "^5.1.5"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.15.0",
    "@vitest/coverage-v8": "^3.2.4",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
